<Window x:Class="FinanzManager.Views.BuchungBearbeitenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Titel}"
        Width="460" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ShowInTaskbar="False">

    <!--
        ====================================================================
        BUCHUNG BEARBEITEN — Modaler Dialog
        ====================================================================
        DataContext wird vom DialogService auf BuchungBearbeitenViewModel
        gesetzt. Die ganze Logik (Validieren, Speichern, Abbrechen) lebt
        im VM. Hier in der View nur Layout und Bindings.

        Wichtige WPF-Pattern in diesem Fenster:
         - IsDefault="True" auf Speichern: Enter-Taste löst es aus
         - IsCancel="True" auf Abbrechen: Esc-Taste schliesst
         - WindowStartupLocation="CenterOwner": öffnet zentriert
           über dem MainWindow
        ====================================================================
    -->
    <Border Padding="24" Background="White" Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Titel -->
                <RowDefinition Height="*" />     <!-- Formular -->
                <RowDefinition Height="Auto" />  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Titel -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Titel}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,16" />

            <!-- Formular -->
            <StackPanel Grid.Row="1">

                <!-- Typ -->
                <TextBlock Text="Typ" FontWeight="SemiBold" Margin="0,4,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton Content="Einnahme"
                                 GroupName="Typ"
                                 IsChecked="{Binding IstEinnahme}"
                                 Margin="0,0,16,0" />
                    <RadioButton Content="Ausgabe"
                                 GroupName="Typ"
                                 IsChecked="{Binding IstAusgabe}" />
                </StackPanel>

                <!-- Datum -->
                <TextBlock Text="Datum" FontWeight="SemiBold" Margin="0,4,0,4" />
                <DatePicker SelectedDate="{Binding Datum}" Margin="0,0,0,12" />

                <!-- Kategorie -->
                <TextBlock Text="Kategorie" FontWeight="SemiBold" Margin="0,4,0,4" />
                <ComboBox ItemsSource="{Binding VerfuegbareKategorien}"
                          SelectedItem="{Binding AusgewaehlteKategorie}"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,12" />

                <!-- Betrag -->
                <TextBlock Text="Betrag (CHF)" FontWeight="SemiBold" Margin="0,4,0,4" />
                <TextBox Text="{Binding Betrag, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                         Margin="0,0,0,12" />

                <!-- Notiz -->
                <TextBlock Text="Notiz (optional)" FontWeight="SemiBold" Margin="0,4,0,4" />
                <TextBox Text="{Binding Notiz, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="60"
                         VerticalScrollBarVisibility="Auto" />

            </StackPanel>

            <!-- Buttons -->
            <DockPanel Grid.Row="2" LastChildFill="False" Margin="0,16,0,0">
                <Button DockPanel.Dock="Right"
                        Content="Abbrechen"
                        Command="{Binding AbbrechenCmd}"
                        IsCancel="True"
                        Padding="16,6"
                        MinWidth="100" />
                <Button DockPanel.Dock="Right"
                        Content="Speichern"
                        Command="{Binding SpeichernCmd}"
                        IsDefault="True"
                        Padding="16,6"
                        MinWidth="100"
                        Margin="0,0,8,0" />
            </DockPanel>

        </Grid>
    </Border>
</Window>
