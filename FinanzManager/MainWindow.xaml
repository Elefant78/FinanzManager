<Window x:Class="FinanzManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FinanzManager.ViewModels"
        mc:Ignorable="d"
        Title="FinanzManager — Persönliches Haushaltsbuch"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <!--
        ====================================================================
        MAINWINDOW — Phase 6 (finale UI)
        ====================================================================
        Bindet an MainViewModel als DataContext.
        - Header mit Logo + Navigation, aktive Sektion wird hervorgehoben
        - ContentControl + DataTemplates für VM-First-Navigation
        ====================================================================
    -->

    <Window.Resources>
        <!--
            Basis-Style für Sidebar-Navigation: graues Schema mit
            sanftem Hover-Effekt. Per Trigger im Button-Style wird
            der "aktive" Zustand eingefärbt.
        -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EDEDED" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header mit Titel + Navigation -->
        <Border Grid.Row="0"
                Background="White"
                Padding="24,14"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FinanzManager"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <!-- Dashboard-Button: aktiver Zustand via DataTrigger -->
                    <Button Content="Dashboard" Command="{Binding ZuDashboardCmd}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IstDashboardAktiv}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Buchungen" Command="{Binding ZuBuchungenCmd}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IstBuchungenAktiv}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Kategorien" Command="{Binding ZuKategorienCmd}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IstKategorienAktiv}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!--
            ContentControl ist DAS WPF-Element für VM-First-Navigation:
            - Der Content ist das CurrentView-Property des MainVM
            - WPF schaut nach einem passenden DataTemplate (DataType="...")
            - Das Template definiert, wie das jeweilige ViewModel
              darzustellen ist
        -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="24,20">

            <ContentControl.Resources>

                <!-- ============================================ -->
                <!-- Template: DashboardViewModel                 -->
                <!-- ============================================ -->
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <StackPanel>
                        <TextBlock Text="Dashboard"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" />

                        <!-- Monats-Navigation -->
                        <DockPanel Margin="0,16,0,0">
                            <Button Content="◀ Voriger"  Command="{Binding VorigerMonatCmd}"  Padding="10,5" Margin="0,0,8,0" />
                            <Button Content="Heute"      Command="{Binding HeutigerMonatCmd}" Padding="10,5" Margin="0,0,8,0" />
                            <Button Content="Nächster ▶" Command="{Binding NaechsterMonatCmd}" Padding="10,5" Margin="0,0,16,0" />
                            <TextBlock Text="{Binding MonatBezeichnung}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Statistik-Kacheln nebeneinander -->
                        <UniformGrid Columns="3" Margin="0,20,0,0">
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,8,0" BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Einnahmen" Foreground="#777" FontSize="13" />
                                    <TextBlock Text="{Binding Statistik.Einnahmen, StringFormat='CHF {0:N2}'}"
                                               FontSize="22" FontWeight="Bold" Foreground="#2E7D32" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="4,0" BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Ausgaben" Foreground="#777" FontSize="13" />
                                    <TextBlock Text="{Binding Statistik.Ausgaben, StringFormat='CHF {0:N2}'}"
                                               FontSize="22" FontWeight="Bold" Foreground="#C62828" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="8,0,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Saldo" Foreground="#777" FontSize="13" />
                                    <TextBlock Text="{Binding Statistik.Saldo, StringFormat='CHF {0:N2}'}"
                                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Letzte Buchungen -->
                        <TextBlock Text="Letzte Buchungen"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,24,0,8" />
                        <Border Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                            <ListView ItemsSource="{Binding LetzteBuchungen}"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Datum"     Width="110" DisplayMemberBinding="{Binding Datum, StringFormat='dd.MM.yyyy'}" />
                                        <GridViewColumn Header="Kategorie" Width="180" DisplayMemberBinding="{Binding Kategorie.Name}" />
                                        <GridViewColumn Header="Betrag"    Width="120" DisplayMemberBinding="{Binding Betrag, StringFormat='F2'}" />
                                        <GridViewColumn Header="Notiz"     Width="380" DisplayMemberBinding="{Binding Notiz}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </StackPanel>
                </DataTemplate>

                <!-- ============================================ -->
                <!-- Template: BuchungenViewModel                 -->
                <!-- ============================================ -->
                <DataTemplate DataType="{x:Type vm:BuchungenViewModel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <TextBlock Text="Buchungen"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" />
                            <Button DockPanel.Dock="Right"
                                    Content="+ Neue Buchung"
                                    Command="{Binding NeueBuchungCmd}"
                                    Padding="14,6"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    BorderThickness="0" />
                        </DockPanel>

                        <Border Grid.Row="1"
                                Background="White"
                                CornerRadius="8"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Margin="0,16,0,0">
                            <ListView ItemsSource="{Binding Buchungen}"
                                      SelectedItem="{Binding AusgewaehlteBuchung}"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Datum"     Width="110" DisplayMemberBinding="{Binding Datum, StringFormat='dd.MM.yyyy'}" />
                                        <GridViewColumn Header="Typ"       Width="90"  DisplayMemberBinding="{Binding Kategorie.Typ}" />
                                        <GridViewColumn Header="Kategorie" Width="170" DisplayMemberBinding="{Binding Kategorie.Name}" />
                                        <GridViewColumn Header="Betrag"    Width="120" DisplayMemberBinding="{Binding Betrag, StringFormat='F2'}" />
                                        <GridViewColumn Header="Notiz"     Width="320" DisplayMemberBinding="{Binding Notiz}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="Bearbeiten"     Command="{Binding BearbeitenCmd}"     Padding="14,6" Margin="0,0,8,0" />
                            <Button Content="Löschen"        Command="{Binding LoeschenCmd}"       Padding="14,6" Margin="0,0,8,0" />
                            <Button Content="Aktualisieren"  Command="{Binding AktualisierenCmd}"  Padding="14,6" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                <!-- ============================================ -->
                <!-- Template: KategorienViewModel                -->
                <!-- ============================================ -->
                <DataTemplate DataType="{x:Type vm:KategorienViewModel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Kategorien"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" />

                        <Border Grid.Row="1"
                                Background="White"
                                CornerRadius="8"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Margin="0,16,0,0">
                            <ListView ItemsSource="{Binding Kategorien}"
                                      SelectedItem="{Binding AusgewaehlteKategorie}"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Name" Width="280" DisplayMemberBinding="{Binding Name}" />
                                        <GridViewColumn Header="Typ"  Width="140" DisplayMemberBinding="{Binding Typ}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>

                        <Border Grid.Row="2"
                                Background="White"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,16,0,0"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Neue Kategorie hinzufügen"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                                <DockPanel Margin="0,12,0,0">
                                    <RadioButton GroupName="NeuTyp"
                                                 Content="Einnahme"
                                                 IsChecked="{Binding NeuIstEinnahme}"
                                                 Margin="0,0,16,0"
                                                 VerticalAlignment="Center" />
                                    <RadioButton GroupName="NeuTyp"
                                                 Content="Ausgabe"
                                                 IsChecked="{Binding NeuIstAusgabe}"
                                                 Margin="0,0,16,0"
                                                 VerticalAlignment="Center" />
                                </DockPanel>
                                <DockPanel Margin="0,10,0,0">
                                    <Button DockPanel.Dock="Right"
                                            Content="Hinzufügen"
                                            Command="{Binding HinzufuegenCmd}"
                                            Padding="14,6"
                                            Margin="8,0,0,0" />
                                    <TextBox Text="{Binding NeuName, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Button Grid.Row="3"
                                Content="Ausgewählte löschen"
                                Command="{Binding LoeschenCmd}"
                                Padding="14,6"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left" />
                    </Grid>
                </DataTemplate>

            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
